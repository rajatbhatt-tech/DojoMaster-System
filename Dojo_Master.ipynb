   "source": [
    "import mysql.connector\n",
    "from datetime import date\n",
    "\n",
    "# --- CONNECTION ---\n",
    "mydb = mysql.connector.connect(\n",
    "  host=\"localhost\",\n",
    "  user=\"root\",\n",
    "  password=\"@@Rb2004@@\", \n",
    "  database=\"DOJOMASTER\"\n",
    ")\n",
    "cursor = mydb.cursor(dictionary=True)\n",
    "\n",
    "class Dojo:\n",
    "    # 1. SETUP (Sabse pehle ye chalega)\n",
    "    def __init__(self):\n",
    "        self.member_list = []\n",
    "        cursor.execute(\"SELECT name, age, belt_level, fees_status FROM member\")\n",
    "        for m in cursor.fetchall():\n",
    "            self.member_list.append(m)\n",
    "\n",
    "    # 2. BASIC MANAGEMENT (Add, Delete, Search, Show)\n",
    "    def add_member(self, name, age, belt_level):\n",
    "        member_data = {\"name\": name, \"age\": age, \"belt_level\": belt_level, \"fees_status\": \"Pending\"}\n",
    "        self.member_list.append(member_data)\n",
    "        sql = \"INSERT INTO member (name, age, belt_level) VALUES (%s, %s, %s)\"\n",
    "        cursor.execute(sql, (name, age, belt_level))\n",
    "        mydb.commit()\n",
    "        print(\"✅ SUCCESS:\", name, \"ka data save ho gaya!\")\n",
    "\n",
    "    def delete_member(self, name):\n",
    "        for m in self.member_list:\n",
    "            if m[\"name\"].lower() == name.lower():\n",
    "                self.member_list.remove(m)\n",
    "                sql = \"DELETE FROM member WHERE name = %s\"\n",
    "                cursor.execute(sql, (name,))\n",
    "                mydb.commit()\n",
    "                print(\"🗑️ REMOVED:\", name, \"ko list se hata diya!\")\n",
    "                return\n",
    "        print(\"❌ NOT FOUND: Ye naam list mein nahi hai.\")\n",
    "\n",
    "    def search_member(self, name):\n",
    "        for m in self.member_list:\n",
    "            if m[\"name\"].lower() == name.lower():\n",
    "                print(\"🔍 FOUND -> Name:\", m[\"name\"], \"| Age:\", m[\"age\"], \"| Belt:\", m[\"belt_level\"])\n",
    "                return\n",
    "        print(\"❓ NOT FOUND\")\n",
    "\n",
    "    def show_all(self):\n",
    "        print(\"\\n--- 👥 ALL MEMBERS ---\")\n",
    "        for m in self.member_list:\n",
    "            print(\"Name:\", m[\"name\"], \"| Belt:\", m[\"belt_level\"], \"| Age:\", m[\"age\"], \"| Fees:\", m.get(\"fees_status\", \"Pending\"))\n",
    "\n",
    "    # 3. ATTENDANCE SYSTEM (Hazari aur Report)\n",
    "    def mark_attendance(self, name):\n",
    "        cursor.execute(\"SELECT member_id FROM member WHERE name = %s\", (name,))\n",
    "        result = cursor.fetchone()\n",
    "        if result:\n",
    "            m_id = result['member_id']\n",
    "            aaj = date.today()\n",
    "            sql = \"INSERT INTO attendances (log_date, status, member_id) VALUES (%s, %s, %s)\"\n",
    "            cursor.execute(sql, (aaj, 'Present', m_id))\n",
    "            mydb.commit()\n",
    "            print(\"📝 PRESENT:\", name, \"ki hazari lag gayi!\")\n",
    "        else:\n",
    "            print(\"❌ ERROR: Database mein ye naam nahi mila.\")\n",
    "\n",
    "    def view_attendance(self):\n",
    "        sql = \"\"\"\n",
    "            SELECT member.name, attendances.log_date, attendances.status \n",
    "            FROM attendances \n",
    "            JOIN member ON attendances.member_id = member.member_id\n",
    "        \"\"\"\n",
    "        cursor.execute(sql)\n",
    "        records = cursor.fetchall()\n",
    "        print(\"\\n--- 📅 ATTENDANCE LOG ---\")\n",
    "        for r in records:\n",
    "            print(\"Date:\", r['log_date'], \"| Name:\", r['name'], \"| Status:\", r['status'])\n",
    "\n",
    "    def monthly_report(self):\n",
    "        sql = \"\"\"\n",
    "            SELECT member.name, COUNT(attendances.log_id) as hazari\n",
    "            FROM member\n",
    "            LEFT JOIN attendances ON member.member_id = attendances.member_id\n"
    "            AND attendances.status = 'Present'\n",
    "            GROUP BY member.name\n",
    "        \"\"\"\n",
    "        cursor.execute(sql)\n",
    "        records = cursor.fetchall()\n",
    "        print(\"\\n📊 --- MONTHLY ATTENDANCE KING ---\")\n",
    "        for r in records:\n",
    "            print(\"Name:\", r['name'], \"| Total Days:\", r['hazari'])\n",
    "\n",
    "    # 4. PROGRESS & PAYMENTS (Promotion aur Fees)\n",
    "    def promote_member(self, name):\n",
    "        belts = [\"White\", \"Yellow\", \"Orange\", \"Green\", \"Blue\", \"Brown\", \"Black\"]\n",
    "        cursor.execute(\"SELECT belt_level FROM member WHERE name = %s\", (name,))\n",
    "        result = cursor.fetchone() \n",
    "        if result:\n",
    "            current = result['belt_level'] \n",
    "            if current in belts:\n",
    "                idx = belts.index(current)\n",
    "                if idx < len(belts) - 1:\n",
    "                    new_belt = belts[idx + 1]\n",
    "                    cursor.execute(\"UPDATE member SET belt_level = %s WHERE name = %s\", (new_belt, name))\n",
    "                    mydb.commit()\n",
    "                    for m in self.member_list:\n",
    "                        if m['name'].lower() == name.lower(): m['belt_level'] = new_belt\n",
    "                    print(\"⭐ CONGRATS:\", name, \"ab\", new_belt, \"belt ho gaya!\")\n",
    "                else:\n",
    "                    print(\"🏆\", name, \"is already a Black Belt!\")\n",
    "        else:\n",
    "            print(\"❌ Member nahi mila!\")\n",
    "\n",
    "    def pay_fees(self, name):\n",
    "        cursor.execute(\"UPDATE member SET fees_status = 'Paid' WHERE name = %s\", (name,))\n",
    "        mydb.commit()\n",
    "        for m in self.member_list:\n",
    "            if m[\"name\"].lower() == name.lower():\n",
    "                m[\"fees_status\"] = \"Paid\"\n",
    "        print(\"💰 FEES PAID: Shukriya,\", name, \"bhai!\")\n",
    "\n",
    "    def export_report(self):\n",
    "       \n",
    "        with open(\"Dojo_Report.txt\", \"w\", encoding=\"utf-8\") as f:\n",
    "            f.write(\"--- 🥋 DOJOMASTER OFFICIAL REPORT ---\\n\")\n",
    "            f.write(\"Date: \" + str(date.today()) + \"\\n\\n\")\n",
    "            f.write(\"Member Name | Belt Level | Fees Status\\n\")\n",
    "            f.write(\"-\" * 40 + \"\\n\")\n",
    "            \n",
    "            for m in self.member_list:\n",
    "                line = m['name'] + \" | \" + m['belt_level'] + \" | \" + m['fees_status'] + \"\\n\"\n",
    "                f.write(line)\n",
    "                \n",
    "        print(\"📁 MAKKHAN! 'Dojo_Report.txt' ban gayi hai, jaakar check kar!\")\n",
    "\n",
    "# --- 5. MAIN INTERFACE ---\n",
    "my_dojo = Dojo()\n",
    "my_dojo.show_all()\n",
    "\n",
    "while True:\n",
    "    cmd = input(\"\\nAction (search, delete, present, view, promote, pay, report, exit) or 'add': \").lower()\n",
    "    \n",
    "    if cmd == 'exit': break\n",
    "    \n",
    "    elif cmd == 'search':\n",
    "        my_dojo.search_member(input(\"Naam? \"))\n",
    "    elif cmd == 'delete':\n",
    "        my_dojo.delete_member(input(\"Kise hatana hai? \"))\n",
    "    elif cmd == 'present':\n",
    "        my_dojo.mark_attendance(input(\"Kaun aaya hai? \"))\n",
    "    elif cmd == 'view':\n",
    "        my_dojo.view_attendance()\n",
    "    elif cmd == 'report':\n",
    "        my_dojo.monthly_report()\n",
    "    elif cmd == 'promote':\n",
    "        my_dojo.promote_member(input(\"Kiska level badhana hai? \"))\n",
    "    elif cmd == 'pay':\n",
    "        my_dojo.pay_fees(input(\"Kiske paise aaye? \"))\n",
    "    elif cmd == 'export':\n",
    "        my_dojo.export_report()\n",
    "    else:\n",
    "        # Naya member add karne ka section\n",
    "        name = input(\"Naya Member Name: \")\n",
    "        try:\n",
    "            age = int(input(\"Age: \"))\n",
    "            belt = input(\"Belt Level: \")\n",
    "            my_dojo.add_member(name, age, belt)\n",
    "        except:\n",
    "            print(\"❌ Age galat dali tune, phir se try kar.\")\n",
    "\n",
    "my_dojo.show_all()"
   ]
  },
